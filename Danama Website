<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Danama Bakery</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif}
body{background:#f5f5f5;color:#333}
header{
    background:linear-gradient(135deg,#128C7E,#25D366);
    color:white;
    padding:40px 20px;
    text-align:center;
}
header h1{font-size:28px}
header p{opacity:0.9}

.container{
    max-width:1000px;
    margin:30px auto;
    padding:20px;
}

.products{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.card{
    background:white;
    border-radius:15px;
    box-shadow:0 10px 20px rgba(0,0,0,0.1);
    padding:15px;
    text-align:center;
}

.card img{
    width:100%;
    border-radius:10px;
    height:180px;
    object-fit:cover;
}

.card h3{margin:10px 0}
.card p{font-weight:bold;color:#128C7E}

.card button{
    background:#25D366;
    color:white;
    border:none;
    padding:10px;
    width:100%;
    border-radius:8px;
    cursor:pointer;
}

.cart{
    margin-top:40px;
    background:white;
    padding:20px;
    border-radius:15px;
    box-shadow:0 10px 20px rgba(0,0,0,0.1);
}

.cart h2{margin-bottom:15px}

.cart-item{
    display:flex;
    justify-content:space-between;
    margin-bottom:8px;
}

.total{
    margin-top:15px;
    font-weight:bold;
    font-size:18px;
}

.form-group{
    margin-top:15px;
}

input,textarea{
    width:100%;
    padding:10px;
    border-radius:8px;
    border:1px solid #ccc;
}

button.checkout{
    margin-top:15px;
    width:100%;
    padding:12px;
    background:#128C7E;
    color:white;
    border:none;
    border-radius:10px;
    font-size:16px;
    cursor:pointer;
}

footer{
    text-align:center;
    margin:40px 0;
    color:#777;
}
</style>
</head>

<body>

<header>
    <h1>Danama Bakery</h1>
    <p>Pemesanan Mudah & Cepat via WhatsApp</p>
</header>

<div class="container">

    <div class="products">
        <div class="card">
            <h3>Kue nastar</h3>
            <p>Rp 80.000</p>
            <button onclick="addToCart('Kue nastar',80000)">Tambah</button>
        </div>

        <div class="card">
            <h3>Kue kacang</h3>
            <p>Rp 80.000</p>
            <button onclick="addToCart('Kue kacang',80000)">Tambah</button>
        </div>

        <div class="card">
            <h3>Coklat mede</h3>
            <p>Rp 85.000</p>
            <button onclick="addToCart('Coklat mede',85000)">Tambah</button>
        </div>

        <div class="card">
            <h3>Kembang Loyang</h3>
            <p>Rp 100.000</p>
            <button onclick="addToCart('Kembang Loyang',100000)">Tambah</button>
        </div>
    </div>

    <div class="cart">
        <h2>Keranjang</h2>
        <div id="cartList"></div>
        <div class="total">Total: Rp <span id="total">0</span></div>

        <div class="form-group">
            <input type="text" id="nama" placeholder="Nama Lengkap">
        </div>

        <div class="form-group">
            <textarea id="alamat" placeholder="Alamat Lengkap"></textarea>
        </div>

        <button class="checkout" onclick="checkout()">Checkout via WhatsApp</button>
    </div>

</div>

<footer>
© 2026 Danama Bakery
</footer>

<script>
let cart = [];

function addToCart(nama,harga){
    cart.push({nama,harga});
    renderCart();
}

function renderCart(){
    let cartList = document.getElementById("cartList");
    cartList.innerHTML="";
    let total=0;

    cart.forEach(item=>{
        total+=item.harga;
        cartList.innerHTML+=`
        <div class="cart-item">
            <span>${item.nama}</span>
            <span>Rp ${item.harga.toLocaleString("id-ID")}</span>
        </div>`;
    });

    document.getElementById("total").innerText=total.toLocaleString("id-ID");
}

function checkout(){
    let nama=document.getElementById("nama").value;
    let alamat=document.getElementById("alamat").value;

    if(cart.length==0){
        alert("Keranjang masih kosong!");
        return;
    }

    let total=document.getElementById("total").innerText;
    let detail="";

    cart.forEach(item=>{
        detail+=item.nama+" - Rp "+item.harga.toLocaleString("id-ID")+"%0A";
    });

    let noWA="6285210195367"; // GANTI NOMOR ANDA

    let pesan="Halo Admin, saya ingin pesan:%0A%0A"+
    detail+
    "%0ATotal: Rp "+total+
    "%0A%0ANama: "+nama+
    "%0AAlamat: "+alamat;

    window.open("https://wa.me/"+noWA+"?text="+pesan,"_blank");
}
</script>

</body>
</html>
